  @@index([query])
  @@index([createdAt])
  @@map("search_query_logs")
}

/// One row per (document type, locale) — the addressable "slot" that always has
/// at most one PUBLISHED version at a time. Content itself lives in LegalDocumentVersion
/// so every edit is versioned and nothing is ever destructively overwritten.
model LegalDocument {
  id        String                 @id @default(cuid())
  type      LegalDocumentType
  locale    String                 @default("en")
  createdAt DateTime               @default(now()) @map("created_at")
  updatedAt DateTime               @updatedAt @map("updated_at")
  versions  LegalDocumentVersion[]

  @@unique([type, locale])
  @@index([type])
  @@map("legal_documents")
}

model LegalDocumentVersion {
  id            String             @id @default(cuid())
  documentId    String             @map("document_id")
  document      LegalDocument      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  versionNumber Int                @map("version_number")
  title         String
  content       String             @db.Text
  format        LegalContentFormat @default(MARKDOWN)
  status        LegalVersionStatus @default(DRAFT)
  effectiveDate DateTime?          @map("effective_date")
  changeSummary String?            @map("change_summary")
  createdById   String?            @map("created_by_id")
  createdBy     User?              @relation("LegalVersionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  publishedById String?            @map("published_by_id")
  publishedBy   User?              @relation("LegalVersionPublishedBy", fields: [publishedById], references: [id], onDelete: SetNull)
  publishedAt   DateTime?          @map("published_at")
  archivedAt    DateTime?          @map("archived_at")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  @@unique([documentId, versionNumber])
  @@index([documentId, status])
  @@index([status])
  @@map("legal_document_versions")
}

enum LegalDocumentType {
  PRIVACY_POLICY
  TERMS_CONDITIONS
  REWARDS_POLICY
  COMMUNITY_GUIDELINES
  VENDOR_TERMS
  CREATOR_TERMS
  REFUND_POLICY
  ABOUT_US
  CONTACT_INFO
  FAQ
}

enum LegalVersionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LegalContentFormat {
  MARKDOWN
  HTML
  PLAIN
}

/// Admin-authored in-app banners/notices (separate from push notifications — these
/// are pulled by clients on demand and shown while active, not delivered as events).
model Announcement {
  id          String               @id @default(cuid())
  title       String
  body        String               @db.Text
  severity    AnnouncementSeverity @default(INFO)
  audience    AnnouncementAudience @default(ALL)
  isActive    Boolean              @default(true)
  startsAt    DateTime?            @map("starts_at")
  endsAt      DateTime?            @map("ends_at")
  linkUrl     String?              @map("link_url")
  linkLabel   String?              @map("link_label")
  createdById String?              @map("created_by_id")
  createdBy   User?                @relation("AnnouncementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  @@index([isActive])
  @@index([audience])
  @@index([startsAt, endsAt])
  @@map("announcements")
}

enum AnnouncementSeverity {
  INFO
  SUCCESS
  WARNING
  CRITICAL
}

enum AnnouncementAudience {
  ALL
  USER
  VENDOR
  CONTENT_CREATOR
}

// ─── Monetization (admin-managed plans; no hardcoded prices in clients) ───

enum PlanAudience {
  USER_PREMIUM
  VENDOR
  CREATOR
}

enum PlanBillingPeriod {
  MONTHLY
  SEMIANNUAL
  YEARLY
  LIFETIME
}

enum PlanStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  GRACE
  CANCELLED
  EXPIRED
  SUSPENDED
}

enum VendorSubscriptionStatus {
  NONE
  ACTIVE
  GRACE
  PAST_DUE
  EXPIRED
  SUSPENDED
}

enum PaymentProvider {
  GOOGLE_PLAY
  APPLE_IAP
  RAZORPAY
  ADMIN_GRANT
}

enum PaymentStatus {
  CREATED
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  CANCELLED
}

enum CouponType {
  PERCENTAGE
  FLAT
  BOGO
}

enum CouponOwnerType {
  ADMIN
  VENDOR
}

enum VendorDocumentType {
  GST
  PAN
  BUSINESS_LICENSE
  SHOP_PHOTO
  OWNER_ID
  BANK_DETAILS
  OTHER
}

enum VendorDocumentStatus {
  PENDING
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

model SubscriptionPlan {
  id                 String       @id @default(cuid())
  audience           PlanAudience
  name               String
  slug               String       @unique
  description        String?      @db.Text
  badge              String?
  color              String?      @default("#B9834B")
  status             PlanStatus   @default(DRAFT)
  sortOrder          Int          @default(0) @map("sort_order")
  /// Feature/limits JSON — maxOffers, maxStaff, analyticsLevel, featuredListing, etc.
  features           Json         @default("{}")
  trialDays          Int          @default(0) @map("trial_days")
  gracePeriodDays    Int          @default(3) @map("grace_period_days")
  googleProductIdMonthly String?  @map("google_product_id_monthly")
  googleProductIdYearly  String?  @map("google_product_id_yearly")
  appleProductIdMonthly  String?  @map("apple_product_id_monthly")
  appleProductIdYearly   String?  @map("apple_product_id_yearly")
  razorpayPlanIdMonthly  String?  @map("razorpay_plan_id_monthly")
  razorpayPlanIdYearly   String?  @map("razorpay_plan_id_yearly")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")
  prices             PlanPrice[]
  subscriptions      UserSubscription[]
  creatorProfiles    CreatorProfile[] @relation("CreatorMembershipPlan")

  @@index([audience, status])
  @@index([sortOrder])
  @@map("subscription_plans")
}

model PlanPrice {
  id            String            @id @default(cuid())
  planId        String            @map("plan_id")
  period        PlanBillingPeriod
  amountPaise   Int               @map("amount_paise")
  currency      String            @default("INR")
  isActive      Boolean           @default(true) @map("is_active")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  plan          SubscriptionPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, period])
  @@index([planId])
  @@map("plan_prices")
}

model UserSubscription {
  id                   String             @id @default(cuid())
  userId               String             @map("user_id")
  planId               String             @map("plan_id")
  audience             PlanAudience
  status               SubscriptionStatus @default(ACTIVE)
  billingPeriod        PlanBillingPeriod  @map("billing_period")
  provider             PaymentProvider
  providerSubscriptionId String?          @map("provider_subscription_id")
  providerCustomerId   String?            @map("provider_customer_id")
  currentPeriodStart   DateTime           @map("current_period_start")
  currentPeriodEnd     DateTime           @map("current_period_end")
  graceEndsAt          DateTime?          @map("grace_ends_at")
  cancelledAt          DateTime?          @map("cancelled_at")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  autoRenew            Boolean            @default(true) @map("auto_renew")
  metadata             Json?
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                 SubscriptionPlan   @relation(fields: [planId], references: [id], onDelete: Restrict)
  transactions         PaymentTransaction[]

  @@index([userId, audience, status])
  @@index([planId])
  @@index([currentPeriodEnd])
  @@index([providerSubscriptionId])
  @@map("user_subscriptions")
}

model PaymentTransaction {
  id                    String          @id @default(cuid())
  userId                String          @map("user_id")
  subscriptionId        String?         @map("subscription_id")
  provider              PaymentProvider
  status                PaymentStatus   @default(CREATED)
  amountPaise           Int             @map("amount_paise")
  currency              String          @default("INR")
  description           String?
  providerPaymentId     String?         @unique @map("provider_payment_id")
  providerOrderId       String?         @map("provider_order_id")
  providerSignature     String?         @map("provider_signature")
  receiptNumber         String?         @unique @map("receipt_number")
  failureReason         String?         @map("failure_reason")
  rawPayload            Json?           @map("raw_payload")
  paidAt                DateTime?       @map("paid_at")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription          UserSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  invoice               Invoice?
  refunds               Refund[]

  @@index([userId])
  @@index([status])
  @@index([providerOrderId])
  @@index([createdAt])
  @@map("payment_transactions")
}

model Invoice {
  id              String             @id @default(cuid())
  userId          String             @map("user_id")
  transactionId   String             @unique @map("transaction_id")
  invoiceNumber   String             @unique @map("invoice_number")
  amountPaise     Int                @map("amount_paise")
  taxPaise        Int                @default(0) @map("tax_paise")
  currency        String             @default("INR")
  gstNumber       String?            @map("gst_number")
  billingName     String?            @map("billing_name")
  billingAddress  String?            @map("billing_address")
  pdfUrl          String?            @map("pdf_url")
  lineItems       Json               @default("[]") @map("line_items")
  issuedAt        DateTime           @default(now()) @map("issued_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction     PaymentTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([issuedAt])
  @@map("invoices")
}

model Refund {
  id                String             @id @default(cuid())
  transactionId     String             @map("transaction_id")
  requestedById     String?            @map("requested_by_id")
  processedById     String?            @map("processed_by_id")
  amountPaise       Int                @map("amount_paise")
  reason            String?
  status            String             @default("PENDING")
  providerRefundId  String?            @map("provider_refund_id")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  transaction       PaymentTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  requestedBy       User?              @relation("RefundRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  processedBy       User?              @relation("RefundProcessor", fields: [processedById], references: [id], onDelete: SetNull)

  @@index([transactionId])
  @@index([status])
  @@map("refunds")
}

model Coupon {
  id              String          @id @default(cuid())
  code            String          @unique
  type            CouponType
  ownerType       CouponOwnerType @default(ADMIN) @map("owner_type")
  vendorId        String?         @map("vendor_id")
  value           Float
  maxDiscount     Float?          @map("max_discount")
  minPurchase     Float?          @map("min_purchase")
  usageLimit      Int?            @map("usage_limit")
  usedCount       Int             @default(0) @map("used_count")
  perUserLimit    Int             @default(1) @map("per_user_limit")
  startsAt        DateTime?       @map("starts_at")
  expiresAt       DateTime?       @map("expires_at")
  isActive        Boolean         @default(true) @map("is_active")
  description     String?
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  vendor          Vendor?         @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  redemptions     CouponRedemption[]

  @@index([vendorId])
  @@index([isActive, expiresAt])
  @@map("coupons")
}

model CouponRedemption {
  id         String   @id @default(cuid())
  couponId   String   @map("coupon_id")
  userId     String   @map("user_id")
  orderRef   String?  @map("order_ref")
  createdAt  DateTime @default(now()) @map("created_at")
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([userId])
  @@map("coupon_redemptions")
}

model VendorDocument {
  id              String               @id @default(cuid())
  vendorId        String               @map("vendor_id")
  type            VendorDocumentType
  fileUrl         String               @map("file_url")
  fileName        String?              @map("file_name")
  status          VendorDocumentStatus @default(PENDING)
  rejectionReason String?              @map("rejection_reason")
  reviewedAt      DateTime?            @map("reviewed_at")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  vendor          Vendor               @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId, type])
  @@index([status])
  @@map("vendor_documents")
}

model AdConfiguration {
  id                      String   @id @default(cuid())
  key                     String   @unique @default("default")
  adsEnabled              Boolean  @default(true) @map("ads_enabled")
  killSwitch              Boolean  @default(false) @map("kill_switch")
  bannerEnabled           Boolean  @default(true) @map("banner_enabled")
  interstitialEnabled     Boolean  @default(true) @map("interstitial_enabled")
  rewardedEnabled         Boolean  @default(true) @map("rewarded_enabled")
  nativeEnabled           Boolean  @default(true) @map("native_enabled")
  interstitialCooldownSec  Int      @default(120) @map("interstitial_cooldown_sec")
  rewardedPoints          Int      @default(10) @map("rewarded_points")
  bannerAdUnitIdAndroid   String?  @map("banner_ad_unit_id_android")
  bannerAdUnitIdIos       String?  @map("banner_ad_unit_id_ios")
  interstitialAdUnitIdAndroid String? @map("interstitial_ad_unit_id_android")
  interstitialAdUnitIdIos String?  @map("interstitial_ad_unit_id_ios")
  rewardedAdUnitIdAndroid String?  @map("rewarded_ad_unit_id_android")
  rewardedAdUnitIdIos     String?  @map("rewarded_ad_unit_id_ios")
  nativeAdUnitIdAndroid   String?  @map("native_ad_unit_id_android")
  nativeAdUnitIdIos       String?  @map("native_ad_unit_id_ios")
  /// ISO country codes; empty = all countries
  enabledCountries        String[] @default([]) @map("enabled_countries")
  /// Semver ranges or exact versions; empty = all
  enabledAppVersions      String[] @default([]) @map("enabled_app_versions")
  metadata                Json?
  updatedAt               DateTime @updatedAt @map("updated_at")
  createdAt               DateTime @default(now()) @map("created_at")

  @@map("ad_configurations")
}
