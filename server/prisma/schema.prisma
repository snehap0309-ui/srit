generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String                 @id @default(cuid())
  email                  String                 @unique
  password               String
  name                   String
  permission             Role                   @default(USER)
  activeMode             Role                   @default(USER) @map("active_mode")
  bio                    String?
  interests              String[]               @default([])
  avatarStyle            Int                    @default(0) @map("avatar_style")
  avatar                 String?
  verificationStatus     VerificationStatus     @default(NONE) @map("verification_status")
  verifiedAt             DateTime?              @map("verified_at")
  verifiedById           String?                @map("verified_by_id")
  verifiedBy             User?                  @relation("VerifiedUsers", fields: [verifiedById], references: [id], onDelete: SetNull)
  verifiedUsers          User[]                 @relation("VerifiedUsers")
  reviewedVendors        Vendor[]               @relation("VendorReviewer")
  createdAt              DateTime               @default(now()) @map("created_at")
  updatedAt              DateTime               @updatedAt @map("updated_at")
  audits                 AuditLog[]             @relation("AuditActor")
  checkIns               CheckIn[]              @relation("UserCheckIns")
  collections            Collection[]           @relation("UserCollections")
  followers              Follow[]               @relation("Followers")
  following              Follow[]               @relation("Following")
  stats                  PlaceStat[]            @relation("UserStats")
  approvedPlaces         Place[]                @relation("ApprovedPlaces")
  submittedPlaces        Place[]                @relation("SubmittedPlaces")
  pointBalance           PointBalance?
  pointTransactions      PointTransaction[]
  redemptions            Redemption[]
  reviews                Review[]               @relation("UserReviews")
  vendorReviews          VendorReview[]         @relation("UserVendorReviews")
  collaborators          TripCollaborator[]
  tripPlans              TripPlan[]             @relation("UserTrips")
  aiGenerationLogs       AiGenerationLog[]
  wallet                 Wallet?
  walletTransactions     WalletTransaction[]
  vendor                 Vendor?
  refreshTokens          RefreshToken[]
  deviceTokens           DeviceToken[]
  notifications          InAppNotification[]
  creatorProfile         CreatorProfile?
  approvedOffers         VendorOffer[]          @relation("ApprovedOffers")
  rejectedOffers         VendorOffer[]          @relation("RejectedOffers")
  refundedRedemptions    Redemption[]           @relation("RefundedRedemptions")
  verifiedRedemptions    Redemption[]           @relation("VerifiedRedemptions")
  questCompletions       QuestCompletion[]
  reelComments           ReelComment[]
  reelLikes              ReelLike[]
  reelSaves              ReelSave[]
  reelReports            ReelReport[]
  rewardClaims           RewardClaim[]
  badges                 String[]               @default([])
  createdChallenges      Challenge[]
  completedChallenges    ChallengeCompletion[]
  userRoles              UserRole[]             @relation("UserRoleAssignments")
  approvedUserRoles      UserRole[]             @relation("UserRoleApprover")
  legalVersionsAuthored  LegalDocumentVersion[] @relation("LegalVersionCreatedBy")
  legalVersionsPublished LegalDocumentVersion[] @relation("LegalVersionPublishedBy")
  announcementsCreated   Announcement[]         @relation("AnnouncementCreatedBy")
  razorpayCustomerId     String?                @map("razorpay_customer_id")
  subscriptions          UserSubscription[]
  paymentTransactions    PaymentTransaction[]
  invoices               Invoice[]
  couponRedemptions      CouponRedemption[]
  refundsRequested       Refund[]               @relation("RefundRequester")
  refundsProcessed       Refund[]               @relation("RefundProcessor")

  @@index([permission])
  @@index([activeMode])
  @@index([verificationStatus])
  @@index([createdAt])
  @@map("users")
}

/// Capability assignments for a single account (multi-role).
/// Source of truth for authz; User.permission is denormalized for dual-write.
model UserRole {
  id             String               @id @default(cuid())
  userId         String               @map("user_id")
  role           Role
  status         RoleAssignmentStatus
  approvedById   String?              @map("approved_by_id")
  approvedAt     DateTime?            @map("approved_at")
  rejectedReason String?              @map("rejected_reason")
  retiredAt      DateTime?            @map("retired_at")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  user           User                 @relation("UserRoleAssignments", fields: [userId], references: [id], onDelete: Cascade)
  approvedBy     User?                @relation("UserRoleApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  @@unique([userId, role])
  @@index([role, status])
  @@index([userId])
  @@map("user_roles")
}

model Vendor {
  id              String          @id @default(cuid())
  userId          String          @unique @map("user_id")
  businessName    String          @map("business_name")
  businessType    String          @map("business_type")
  phone           String
  address         String
  city            String
  state           String
  latitude        Float?
  longitude       Float?
  description     String?
  imageUrl        String?         @map("image_url")
  website         String?
  operatingHours  String?         @map("operating_hours")
  images          String[]        @default([])
  status          VendorStatus    @default(PENDING)
  rejectionReason String?         @map("rejection_reason")
  vendorCode      String?         @unique @map("vendor_code")
  reviewedById    String?         @map("reviewed_by_id")
  reviewedAt      DateTime?       @map("reviewed_at")
  linkedSpotIds   String[]        @map("linked_spot_ids")
  services        Json?           @map("services")
  showOnMap       Boolean         @default(true) @map("show_on_map")
  showContact     Boolean         @default(true) @map("show_contact")
  showWebsite     Boolean         @default(true) @map("show_website")
  showImages      Boolean         @default(true) @map("show_images")
  showOffers      Boolean         @default(true) @map("show_offers")
  showReels       Boolean         @default(true) @map("show_reels")
  showNavigation  Boolean         @default(true) @map("show_navigation")
  gstNumber       String?         @map("gst_number")
  documents       String[]        @default([])
  rating          Float?
  reviewCount     Int             @default(0) @map("review_count")
  subscriptionStatus VendorSubscriptionStatus @default(NONE) @map("subscription_status")
  suspendedAt     DateTime?       @map("suspended_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  redemptions     Redemption[]
  offers          VendorOffer[]
  reels           VendorReel[]
  vendorReviews   VendorReview[]
  vendorDocuments VendorDocument[]
  coupons         Coupon[]
  reviewedBy      User?           @relation("VendorReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  rewards         RewardCatalog[]
  socialReels     Reel[]

  @@index([status])
  @@index([city])
  @@index([state])
  @@index([businessType])
  @@index([latitude, longitude])
  @@index([createdAt])
  @@index([rating])
  @@map("vendors")
}

model VendorOffer {
  id                 String          @id @default(cuid())
  vendorId           String          @map("vendor_id")
  title              String
  description        String?
  banner             String?         @map("banner")
  discountType       String          @map("discount_type")
  discountValue      Float           @map("discount_value")
  pointsRequired     Int             @map("points_required")
  minBillAmount      Float?          @map("min_bill_amount")
  couponCode         String?         @map("coupon_code")
  dailyLimit         Int?            @map("daily_limit")
  validTill          String?         @map("valid_till")
  category           String?         @map("category")
  imageUrl           String?         @map("image_url")
  startDate          DateTime?       @map("start_date")
  maxRedemptions     Int?            @map("max_redemptions")
  currentRedemptions Int             @default(0) @map("current_redemptions")
  viewCount          Int             @default(0) @map("view_count")
  clickCount         Int             @default(0) @map("click_count")
  isFeatured         Boolean         @default(false) @map("is_featured")
  isApproved         Boolean         @default(false) @map("is_approved")
  approvedById       String?         @map("approved_by_id")
  approvedAt         DateTime?       @map("approved_at")
  rejectionReason    String?         @map("rejection_reason")
  rejectedById       String?         @map("rejected_by_id")
  rejectedAt         DateTime?       @map("rejected_at")
  isActive           Boolean         @default(true) @map("is_active")
  pausedAt           DateTime?       @map("paused_at")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  redemptions        Redemption[]
  vendor             Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  approvedBy         User?           @relation("ApprovedOffers", fields: [approvedById], references: [id], onDelete: SetNull)
  rejectedBy         User?           @relation("RejectedOffers", fields: [rejectedById], references: [id], onDelete: SetNull)
  catalogEntries     RewardCatalog[]

  @@index([vendorId])
  @@index([category])
  @@index([isApproved, isActive])
  @@map("vendor_offers")
}

model VendorReel {
  id          String   @id @default(cuid())
  vendorId    String   @map("vendor_id")
  videoUrl    String   @map("video_url")
  thumbnail   String?
  title       String?
  description String?
  views       Int      @default(0)
  likes       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  vendor      Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@map("vendor_reels")
}

model PointBalance {
  id             String   @id @default(cuid())
  userId         String   @unique @map("user_id")
  balance        Int      @default(0)
  lifetimeEarned Int      @default(0) @map("lifetime_earned")
  lifetimeSpent  Int      @default(0) @map("lifetime_spent")
  updatedAt      DateTime @updatedAt @map("updated_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("point_balances")
}

model PointTransaction {
  id          String          @id @default(cuid())
  userId      String?         @map("user_id")
  amount      Int
  type        TransactionType @default(EARN)
  reason      String
  referenceId String?         @map("reference_id")
  createdAt   DateTime        @default(now()) @map("created_at")
  user        User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@map("point_transactions")
}

model Redemption {
  id            String           @id @default(cuid())
  userId        String?          @map("user_id")
  offerId       String?          @map("offer_id")
  vendorId      String?          @map("vendor_id")
  pointsSpent   Int              @map("points_spent")
  discountValue Float            @map("discount_value")
  discountType  String           @map("discount_type")
  qrCode        String           @unique @map("qr_code")
  receiptNumber String?          @unique @map("receipt_number")
  status        RedemptionStatus @default(PENDING)
  verifiedAt    DateTime?        @map("verified_at")
  verifiedById  String?          @map("verified_by_id")
  verifiedBy    User?            @relation("VerifiedRedemptions", fields: [verifiedById], references: [id], onDelete: SetNull)
  refundedAt    DateTime?        @map("refunded_at")
  refundedById  String?          @map("refunded_by_id")
  notes         String?
  token         RedemptionToken?
  createdAt     DateTime         @default(now()) @map("created_at")
  offer         VendorOffer?     @relation(fields: [offerId], references: [id], onDelete: SetNull)
  user          User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  vendor        Vendor?          @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  refundedBy    User?            @relation("RefundedRedemptions", fields: [refundedById], references: [id], onDelete: SetNull)

  @@index([offerId])
  @@index([userId])
  @@index([vendorId])
  @@index([qrCode])
  @@index([status])
  @@index([createdAt])
  @@index([status, offerId])
  @@map("redemptions")
}

model Wallet {
  id             String @id @default(cuid())
  userId         String @unique @map("user_id")
  palPoints      Int    @default(0) @map("pal_points")
  lifetimeEarned Int    @default(0) @map("lifetime_earned")
  lifetimeSpent  Int    @default(0) @map("lifetime_spent")

  updatedAt    DateTime            @updatedAt @map("updated_at")
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id            String          @id @default(cuid())
  walletId      String?         @map("wallet_id")
  userId        String?         @map("user_id")
  amount        Int
  type          TransactionType @default(EARN)
  reason        String
  referenceId   String?         @map("reference_id")
  referenceType String?         @map("reference_type")
  metadata      Json?           @map("metadata")
  createdAt     DateTime        @default(now()) @map("created_at")
  wallet        Wallet?         @relation(fields: [walletId], references: [id], onDelete: SetNull)
  user          User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([walletId])
  @@index([userId])
  @@index([createdAt])
  @@map("wallet_transactions")
}

model RedemptionToken {
  id           String     @id @default(cuid())
  redemptionId String     @unique @map("redemption_id")
  token        String     @unique
  expiresAt    DateTime   @map("expires_at")
  usedAt       DateTime?  @map("used_at")
  usedById     String?    @map("used_by_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  redemption   Redemption @relation(fields: [redemptionId], references: [id], onDelete: Cascade)

  @@map("redemption_tokens")
}

model PointRule {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String?
  points      Int
  xpAmount    Int      @default(0) @map("xp_amount")
  category    String   @default("general")
  isActive    Boolean  @default(true) @map("is_active")
  cooldownSec Int?     @map("cooldown_sec")
  maxDaily    Int?     @map("max_daily")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([category, isActive])
  @@map("point_rules")
}

model RewardCatalog {
  id             String       @id @default(cuid())
  title          String
  description    String?
  category       String
  pointsRequired Int          @map("points_required")
  value          String?
  imageUrl       String?      @map("image_url")
  vendorId       String?      @map("vendor_id")
  vendorOfferId  String?      @map("vendor_offer_id")
  isActive       Boolean      @default(true) @map("is_active")
  sortOrder      Int          @default(0) @map("sort_order")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  vendor         Vendor?      @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  vendorOffer    VendorOffer? @relation(fields: [vendorOfferId], references: [id], onDelete: SetNull)

  @@index([category, isActive])
  @@index([pointsRequired])
  @@map("reward_catalog")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")
  follower    User     @relation("Followers", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model Place {
  id                       String                   @id @default(cuid())
  name                     String
  slug                     String                   @unique
  description              String
  shortDescription         String?                  @map("short_description")
  history                  String?                  @db.Text
  latitude                 Float?
  longitude                Float?
  category                 String
  tags                     String[]                 @default([])
  images                   String[]                 @default([])
  thumbnail                String?
  city                     String                   @default("")
  state                    String                   @default("")
  country                  String                   @default("India")
  rating                   Float?
  reviewCount              Int                      @default(0) @map("review_count")
  openingHours             Json?                    @map("opening_hours")
  ticketPrice              Json?                    @map("ticket_price")
  bestTimeToVisit          Json?                    @map("best_time_to_visit")
  bestTimeReason           String?                  @map("best_time_reason")
  recommendedDuration      String?                  @map("recommended_duration")
  estimatedDurationMinutes Int?                     @map("estimated_duration_minutes")
  hasParking               Boolean                  @default(false) @map("has_parking")
  parkingDetails           String?                  @map("parking_details")
  isAccessible             Boolean                  @default(false) @map("is_accessible")
  accessibilityDetails     String?                  @map("accessibility_details")
  hasWashroom              Boolean                  @default(false) @map("has_washroom")
  isPetFriendly            Boolean                  @default(false) @map("is_pet_friendly")
  website                  String?
  emergencyContact         String?                  @map("emergency_contact")
  hiddenGemScore           Float?                   @map("hidden_gem_score")
  popularityScore          Float?                   @map("popularity_score")
  verificationLevel        Int                      @default(0) @map("verification_level")
  status                   PlaceStatus              @default(PENDING)
  source                   PlaceSource              @default(HIDDEN_GEM)
  externalId               String?                  @unique @map("external_id")
  submittedById            String?                  @map("submitted_by_id")
  approvedById             String?                  @map("approved_by_id")
  reviewedAt               DateTime?                @map("reviewed_at")
  createdAt                DateTime                 @default(now()) @map("created_at")
  updatedAt                DateTime                 @updatedAt @map("updated_at")
  location                 Unsupported("geometry")?
  searchVector             Unsupported("tsvector")? @map("search_vector")
  audits                   AuditLog[]
  checkIns                 CheckIn[]
  collections              CollectionPlace[]
  events                   PlaceEvent[]
  placeImages              PlaceImage[]
  offers                   PlaceOffer[]
  stats                    PlaceStat[]
  placeVideos              PlaceVideo[]
  approvedBy               User?                    @relation("ApprovedPlaces", fields: [approvedById], references: [id], onDelete: SetNull)
  submittedBy              User?                    @relation("SubmittedPlaces", fields: [submittedById], references: [id], onDelete: SetNull)
  rejectionReason          String?                  @map("rejection_reason")
  reviews                  Review[]
  tripStops                TripPlanStop[]
  reels                    Reel[]

  @@index([status])
  @@index([category])
  @@index([latitude, longitude])
  @@index([submittedById])
  @@index([source])
  @@index([externalId])
  @@index([city])
  @@index([state])
  @@index([city, state])
  @@index([popularityScore])
  @@index([hiddenGemScore])
  @@index([rating])
  @@index([createdAt])
  @@index([status, category])
  @@index([source, status])
  @@index([status, latitude, longitude])
  @@index([searchVector], type: Gin)
  @@map("places")
}

model PlaceImage {
  id        String   @id @default(cuid())
  placeId   String   @map("place_id")
  url       String
  caption   String?
  isPrimary Boolean  @default(false) @map("is_primary")
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId])
  @@index([placeId, url])
  @@map("place_images")
}

/// Tombstone so admin-deleted places are never recreated by seed/import.
model DeletedPlaceRef {
  id         String   @id @default(cuid())
  slug       String   @unique
  curatedId  String?  @map("curated_id")
  name       String
  city       String   @default("")
  state      String   @default("")
  externalId String?  @map("external_id")
  deletedById String? @map("deleted_by_id")
  deletedAt  DateTime @default(now()) @map("deleted_at")

  @@index([curatedId])
  @@index([name, city, state])
  @@index([externalId])
  @@map("deleted_place_refs")
}

model PlaceVideo {
  id        String   @id @default(cuid())
  placeId   String   @map("place_id")
  url       String
  thumbnail String?
  title     String?
  duration  Int?
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId])
  @@map("place_videos")
}

model PlaceOffer {
  id          String    @id @default(cuid())
  placeId     String    @map("place_id")
  title       String
  description String?
  discount    String?
  validFrom   DateTime? @map("valid_from")
  validUntil  DateTime? @map("valid_until")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  place       Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId])
  @@map("place_offers")
}

model PlaceEvent {
  id          String    @id @default(cuid())
  placeId     String    @map("place_id")
  title       String
  description String?
  imageUrl    String?   @map("image_url")
  startDate   DateTime  @map("start_date")
  endDate     DateTime? @map("end_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  place       Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)
  reels       Reel[]

  @@index([placeId])
  @@index([startDate])
  @@map("place_events")
}

model Review {
  id           String   @id @default(cuid())
  placeId      String   @map("place_id")
  userId       String   @map("user_id")
  rating       Int
  content      String?
  photos       String[] @default([])
  helpfulVotes Int      @default(0) @map("helpful_votes")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  place        Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user         User     @relation("UserReviews", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([placeId, userId])
  @@index([placeId])
  @@index([userId])
  @@index([rating])
  @@index([createdAt])
  @@map("reviews")
}

model VendorReview {
  id           String   @id @default(cuid())
  vendorId     String   @map("vendor_id")
  userId       String   @map("user_id")
  rating       Int
  content      String?
  photos       String[] @default([])
  helpfulVotes Int      @default(0) @map("helpful_votes")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  vendor       Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  user         User     @relation("UserVendorReviews", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([vendorId, userId])
  @@index([vendorId])
  @@index([userId])
  @@index([rating])
  @@index([createdAt])
  @@map("vendor_reviews")
}

model CheckIn {
  id        String   @id @default(cuid())
  placeId   String   @map("place_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user      User     @relation("UserCheckIns", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([placeId, userId])
  @@index([placeId])
  @@index([userId])
  @@index([createdAt])
  @@index([createdAt, userId])
  @@index([placeId, userId])
  @@map("check_ins")
}

model PlaceStat {
  id        String   @id @default(cuid())
  placeId   String
  userId    String?
  action    String   @default("view")
  metadata  Json?    @map("metadata")
  createdAt DateTime @default(now()) @map("created_at")
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user      User?    @relation("UserStats", fields: [userId], references: [id], onDelete: SetNull)

  @@index([placeId])
  @@index([action])
  @@index([userId])
  @@index([placeId, action])
  @@index([createdAt])
  @@map("place_stats")
}

model Collection {
  id          String            @id @default(cuid())
  name        String
  description String?
  isPublic    Boolean           @default(true) @map("is_public")
  userId      String            @map("user_id")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  places      CollectionPlace[]
