{
  "name": "palsasafar-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc && prisma generate",
    "prestart": "prisma migrate deploy",
    "start": "prisma migrate deploy && node dist/index.js",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "ts-node prisma/seed.ts",
    "db:seed:curated": "ts-node prisma/seed-curated-places.ts",
    "db:seed:wikidata": "ts-node prisma/seed-wikidata-places.ts",
    "db:seed:osm": "ts-node prisma/seed-osm.ts",
    "db:fetch:osm": "node ../scripts/fetch-india-places-expand.cjs",
    "db:seed:places": "npm run db:seed:curated && npm run db:seed:wikidata && npm run db:seed:osm",
    "db:seed:places:fresh": "npm run db:fetch:osm && npm run db:seed:places && npm run db:cleanup:places",
    "db:seed:production": "ts-node prisma/seed-production.ts",
    "db:seed:legal": "ts-node prisma/seed-legal-documents.ts",
    "db:seed:bulk": "ts-node scripts/generate-bulk-data.ts",
    "db:clear-places": "ts-node scripts/remove-all-places.ts",
    "db:dedupe": "node scripts/remove-place-duplicates.cjs",
    "db:dedupe:dry": "node scripts/remove-place-duplicates.cjs --dry-run",
    "db:cleanup:places": "node scripts/cleanup-genuine-places.cjs",
    "db:extract:curated": "node ../scripts/extract-curated-places.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "db:studio": "prisma studio",
    "verify:credentials": "node scripts/verify-credentials.cjs",
    "db:prune-users": "ts-node scripts/prune-extra-users.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "@sentry/node": "^10.54.0",
    "@sentry/profiling-node": "^10.54.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.2",
    "@types/nodemailer": "^8.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.6.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "firebase-admin": "^14.0.0",
    "googleapis": "^148.0.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2",
    "nodemailer": "^9.0.3",
    "pdfkit": "^0.19.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "razorpay": "^2.9.8",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.15.2",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "prisma": "^6.6.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.7"
  }
}
