# ── Server ──
PORT=5000
NODE_ENV=development

# ── Database (PostgreSQL) ──
# Pooled connection for runtime
DATABASE_URL=postgresql://user:password@your-host:5432/db?sslmode=require
# Direct connection for migrations
DIRECT_URL=postgresql://user:password@your-host:5432/db?sslmode=require

# ── Auth ──
JWT_SECRET=your-secret-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=1h

# ── Cloudinary ──
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Client ──
CLIENT_URL=http://localhost:3000

# ── Firebase Cloud Messaging (for push notifications) ──
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# ── Sentry (optional) ──
SENTRY_DSN=

# ── Email (required for forgot-password) ──
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

# ── AI (optional — enables trip planner / discover) ──
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── Redis (optional — for distributed cache/rate limits in multi-instance deploys) ──
REDIS_URL=

# ── Seed / test accounts (development only) ──
# In production, credential sync is OFF unless SYNC_CANONICAL_CREDENTIALS=true (demo DBs only).
# In development, sync runs unless explicitly set to false.
SYNC_CANONICAL_CREDENTIALS=false
SYNC_CURATED_PLACES=false
# OPT-IN: delete every user except the 4 canonical test accounts on startup.
# Leave unset/false in production so real signups are kept across restarts.
PRUNE_EXTRA_USERS=false
SEED_VENDOR_PASSWORD=Vendor@123
SEED_CREATOR_PASSWORD=Creator@123
SEED_VENDOR_EMAIL=vendor_user_1@palsafar.com
